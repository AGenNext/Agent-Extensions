# Alpha deployment environment

# Backend
BACKEND_PORT=3100

# GitHub webhook bridge
GITHUB_APP_PORT=3000
AGENT_BACKEND_URL=http://backend:3100

# GitHub App / webhook settings
GITHUB_WEBHOOK_SECRET=replace-with-generated-secret
GITHUB_TOKEN=replace-with-token-or-installation-token-flow

# Runtime mode
AGENT_RUNTIME_MODE=alpha
AGENT_SOURCE_OF_TRUTH=backend
AGENT_PREFERRED_RUNTIME=puter.js
